{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go mod tidy)",
      "Bash(go mod graph:*)",
      "Bash(go doc:*)",
      "Bash(go list:*)",
      "Bash(go version:*)",
      "Bash(go tool cover:*)",
      "Bash(make build:*)",
      "Bash(make test:*)",
      "Bash(make lint)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(gh pr:*)",
      "mcp__plugin_github_github__pull_request_read",
      "mcp__plugin_github_github__get_me",
      "mcp__plugin_github_github__list_pull_requests",
      "mcp__plugin_github_github__search_pull_requests",
      "mcp__plugin_linear_linear__get_issue",
      "mcp__plugin_linear_linear__list_teams"
    ],
    "deny": [
      "Read(.env*)",
      "Read(.secrets/**)",
      "Edit(.env*)"
    ]
  },

  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "linear@claude-plugins-official": true
  }
}
