should render a single inline manifest and interpolate release values via tpl:
  1: |
    apiVersion: v1
    data:
      key: value
    kind: ConfigMap
    metadata:
      name: my-config
      namespace: my-gateway-ns
should render multiple inline manifests:
  1: |
    apiVersion: v1
    data:
      key: value
    kind: ConfigMap
    metadata:
      name: cm-one
  2: |
    apiVersion: v1
    data:
      key: value
    kind: ConfigMap
    metadata:
      name: cm-two
should render string-form entries and interpolate release values via tpl:
  1: |
    apiVersion: v1
    data:
      key: value
    kind: ConfigMap
    metadata:
      name: cm-from-string
      namespace: my-gateway-ns
