should render bootstrap Issuer, CA Certificate, and CA Issuer:
  1: |
    apiVersion: cert-manager.io/v1
    kind: Issuer
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: gateway
        app.kubernetes.io/version: 0.1.0
        helm.sh/chart: gateway-0.1.0
      name: RELEASE-NAME-gateway-selfsigned-issuer
    spec:
      selfSigned: {}
  2: |
    apiVersion: cert-manager.io/v1
    kind: Certificate
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: gateway
        app.kubernetes.io/version: 0.1.0
        helm.sh/chart: gateway-0.1.0
      name: RELEASE-NAME-gateway-ca-crt
    spec:
      commonName: RELEASE-NAME-gateway-ca
      isCA: true
      issuerRef:
        kind: Issuer
        name: RELEASE-NAME-gateway-selfsigned-issuer
      secretName: RELEASE-NAME-gateway-ca-crt
  3: |
    apiVersion: cert-manager.io/v1
    kind: Issuer
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: gateway
        app.kubernetes.io/version: 0.1.0
        helm.sh/chart: gateway-0.1.0
      name: RELEASE-NAME-gateway-ca-issuer
    spec:
      ca:
        secretName: RELEASE-NAME-gateway-ca-crt
